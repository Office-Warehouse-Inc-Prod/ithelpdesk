CREATE ALGORITHM=UNDEFINED DEFINER=`root`@`localhost` SQL SECURITY DEFINER VIEW `vw_usrmtc_data` AS select `users`.`id` AS `id`,`users`.`fname` AS `fname`,`users`.`lstname` AS `lstname`,concat_ws(' ',`users`.`fname`,`users`.`lstname`) AS `flName`,`users`.`email` AS `email`,`users`.`password` AS `password`,`users`.`tech_id` AS `tech_id`,`users`.`role` AS `role`,`users`.`dept_id` AS `dept_id`,`tbl_dept`.`dept_desc` AS `dept_desc`,`users`.`str_num` AS `str_num`,`tbl_branch`.`str_code` AS `str_code`,`users`.`img_name` AS `img_name`,`users`.`usr_stat` AS `usr_stat` from ((`users` join `tbl_dept` on(`tbl_dept`.`dept_id` = `users`.`dept_id`)) join `tbl_branch` on(`tbl_branch`.`str_num` = `users`.`str_num`));

-- ----------------------------
--  View definition for `vw_wfit`
-- ----------------------------
DROP VIEW IF EXISTS `vw_wfit`;
CREATE ALGORITHM=UNDEFINED DEFINER=`root`@`localhost` SQL SECURITY DEFINER VIEW `vw_wfit` AS select `status`.`stat_id` AS `stat_id`,`reports`.`status` AS `status`,count(`status`.`stat_id`) AS `cnt_wfit` from (`reports` join `status` on(`status`.`stat_desc` = `reports`.`status`)) where `status`.`stat_id` = '6';

-- ----------------------------
--  View definition for `vw_wfittable`
